# SwiftFormat Configuration

# Disable rules that remove Swift Testing @Suite annotations
--disable redundantSwiftTestingSuite

# Disable test case name rewriting (testFoo -> foo)
--disable swiftTestingTestCaseNames

# Disable preferKeyPath for Swift Testing #expect compatibility (keyPaths throw in #expect context)
--disable preferKeyPath

# Exclude generated/external code
--exclude DerivedData Pods .build build
